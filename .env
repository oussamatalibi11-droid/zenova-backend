# ─────────────────────────────────────────────
# Zenova Agency — Backend environment template
# Copy this file to ".env" and fill in real values.
# NEVER commit the real ".env" to git.
# ─────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=5000

# CORS — comma-separated list of allowed frontend origins
# Example: https://zenova.agency,https://zenova.netlify.app,http://localhost:5500
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500

# ── Email (Gmail SMTP via App Password) ──
# 1) Enable 2-Step Verification on the Gmail account
# 2) Create an App Password: https://myaccount.google.com/apppasswords
# 3) Paste the 16-char password (no spaces) below
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=zenova.digital1@gmail.com
SMTP_PASS=GETALIFE2001@

# Where notifications are sent (your inbox)
NOTIFY_EMAIL=zenova.digital1@gmail.com
# What clients see as the "From" address
MAIL_FROM_NAME=Zenova Agency
MAIL_FROM_ADDRESS=zenova.digital1@gmail.com

# ── WhatsApp ──
# Choose ONE provider: "meta" (Cloud API) or "twilio"
WHATSAPP_PROVIDER=meta

# Phone that receives the lead notifications (E.164, no spaces)
WHATSAPP_TO=+212650133502

# --- Meta WhatsApp Cloud API ---
# Get these from https://developers.facebook.com/ (WhatsApp > API Setup)
META_WA_TOKEN=your_meta_permanent_access_token
META_WA_PHONE_NUMBER_ID=your_phone_number_id
# Pre-approved template name (e.g. "lead_notification") — see README
META_WA_TEMPLATE_NAME=lead_notification
META_WA_TEMPLATE_LANG=en_US

# --- Twilio WhatsApp (alternative) ---
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Anti-spam ──
# Honeypot field name (must match the hidden field in your frontend form)
HONEYPOT_FIELD=website
# Max requests per window per IP for the contact endpoint
RATE_LIMIT_MAX=5
RATE_LIMIT_WINDOW_MINUTES=10
